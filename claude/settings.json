{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-code-notification"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "av-cli@aviator-plugins": true,
    "notion-iac@makenotion-plugins": true,
    "notion-observability@makenotion-plugins": true,
    "notion-infrasec@makenotion-plugins": true
  },
  "extraKnownMarketplaces": {
    "aviator-plugins": {
      "source": {
        "source": "github",
        "repo": "aviator-co/agent-plugins"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "fastMode": true,
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "defaultMode": "plan"
  }
}
