#!/usr/bin/env bash
# pre-push hook: Run tests for changed files before pushing (notion-next only)

repo_name=$(basename "$(git rev-parse --show-toplevel)")

# Only run for notion-next repos (including worktrees like notion-next-1)
if [[ ! "$repo_name" =~ ^notion-next(-[0-9]+)?$ ]]; then
  exit 0
fi

# Scope tests to the diff against this branch's av stack parent. av has no
# command that prints the parent, so read it from av's metadata db (kept in
# the git common dir so worktrees share one). Fall back to origin's default
# branch when the branch isn't part of an av stack.
cur_branch=$(git symbolic-ref --short HEAD 2>/dev/null)
av_db="$(git rev-parse --git-common-dir 2>/dev/null)/av/av.db"
base_ref=$(jq -r --arg b "$cur_branch" '.branches[$b].parent.name // empty' "$av_db" 2>/dev/null)
if [ -z "$base_ref" ]; then
  base_ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/@@')
  base_ref=${base_ref:-origin/main}
  echo "[pre-push] no av stack parent found; using fallback base $base_ref" >&2
fi
merge_base=$(git merge-base HEAD "$base_ref" 2>/dev/null)

# Nothing to check if we can't resolve a merge base (e.g. the av parent points
# at a branch not present locally) or HEAD is identical to the base (e.g. boxy
# creating a new branch off main and pushing it for the first time).
if [ -z "$merge_base" ] || [ "$(git rev-parse HEAD)" = "$(git rev-parse "$merge_base")" ]; then
  exit 0
fi

# Catch codegen/lint/format drift that rebases miss: pre-commit doesn't fire
# during `git rebase`, so commits can land on top of a new main without the
# lint-staged tasks re-running. Replay lint-staged against the diff range,
# then compare the tree before/after — any delta means something needed
# regenerating and didn't.

ls_exit=0
if [ -n "$merge_base" ] && [ -x ./node_modules/.bin/lint-staged ]; then
  # Ensure deps are current before lint-staged runs notion commands —
  # otherwise `notion codegen extract` discovers the mismatch mid-hook
  # and fails on the interactive install fallback prompt.
  ./src/cli/notion install-node-modules

  echo ""
  echo "Replaying lint-staged against $base_ref...HEAD..."
  echo ""
  pre_diff=$(git diff HEAD)
  ./node_modules/.bin/lint-staged --diff="$merge_base..HEAD"
  ls_exit=$?
  post_diff=$(git diff HEAD)
  if [ "$pre_diff" != "$post_diff" ]; then
    echo ""
    echo "lint-staged produced changes — commit them and re-push."
    git status --short
    echo ""
    echo "Push aborted. Use 'git push --no-verify' to skip."
    echo ""
    exit 1
  fi
fi

echo ""
echo "Running tests for changed files before push..."
echo ""

# Run test-changed script directly (not via `dotfiles` wrapper, which cd's
# to the scripts dir and would break git context for worktrees).
#
# Per-push knobs (set on the `git push` invocation):
#   RUN_INTEGRATION=1 git push   -> only integration tests for changed files
#   RUN_ALL_TESTS=1   git push   -> unit + integration
#   TEST_CAP=0        git push   -> disable cap (run everything discovered)
#   TEST_CAP=100      git push   -> raise cap to 100
extra_args=()
[ -n "${RUN_INTEGRATION:-}" ] && extra_args+=(--integration)
[ -n "${RUN_ALL_TESTS:-}" ]   && extra_args+=(--all)
[ -n "${TEST_CAP:-}" ]        && extra_args+=(--cap "$TEST_CAP")
~/code/dotfiles/scripts/test-changed.sh --base "$base_ref" "${extra_args[@]}"
test_exit=$?

# Full typecheck only runs on boxy — it's too slow to block pushes locally.
tc_exit=0
if [[ -n "${NOTION_BOXY_NAME:-}" ]]; then
  echo ""
  echo "Running typecheck..."
  echo ""
  notion typecheck
  tc_exit=$?
fi

if [ $ls_exit -ne 0 ] || [ $test_exit -ne 0 ] || [ $tc_exit -ne 0 ]; then
  echo ""
  [ $ls_exit -ne 0 ] && echo "lint-staged failed."
  [ $test_exit -ne 0 ] && echo "Tests failed."
  [ $tc_exit -ne 0 ] && echo "Typecheck failed."
  echo "Push aborted. Use 'git push --no-verify' to skip."
  echo ""
  exit 1
fi

exit 0
